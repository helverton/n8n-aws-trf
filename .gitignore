# Terraform state — nunca versionar
.terraform/
*.tfstate
*.tfstate.backup
.terraform.lock.hcl

# Variáveis sensíveis — nunca versionar
# EXCEÇÃO: environments/prod/terraform.tfvars é versionado pois contém
# apenas valores não sensíveis (cloudflare_zone_id, n8n_domain, etc.)
# Valores sensíveis devem ir para GitHub Secrets
*.tfvars.local
*.auto.tfvars

# Arquivos temporários
/tmp/
override.tf
crash.log
*.zip
